#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1
PROG=/usr/bin/ai-monitor.sh

start_service() {
    [ -x "$PROG" ] || return 1
    procd_open_instance
    procd_set_param command "$PROG"
    procd_set_param respawn 3600 5 86400
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "ai-monitor"
}

stop_service() {
    killall ai-monitor.sh 2>/dev/null
}
